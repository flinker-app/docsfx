{
  "build": {
    "content": [
      {
        "files": [
          "**/*.md",
          "404.html"
        ]
      }
    ],
    "exclude": [
      "_site/**"
    ],
    "resource": [
      {
        "files": [
          "_media/**",
          "favicon.ico"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "my-template"
    ],
    "fileMetadataFiles": [
      ".docfx/last-updated.json"
    ],
    "styles": [
      "my-template/public/main.css"
    ]
  },
  "sitemap": {
    "baseUrl": "https://docs.flinker.app"
  },
  "globalMetadata": {
    "_appName": "Documentation",
    "_appTitle": "Documentation",
    "ifcViewerSdkVersion": "v3.4.2",
    "_enableNewTab": true,
    "_appLogoPath": "_media/flinker-icon.png",
    "_appFaviconPath": "favicon.ico",
    "_appFooter": "<div class=\"footer-layout\">\n  <ul class=\"links\" data-bi-name=\"footerlinks\">\n    <li><a href=\"https://docs.flinker.app/\">Docs</a></li>\n    <li><a href=\"https://outlook.office365.com/book/SupportConsultingonlinemeeting@flinker.app/\">Support</a></li>\n    <li><a href=\"https://www.flinker.app/data-protection\">Privacy</a></li>\n    <li><a href=\"https://www.flinker.app/legal\">Legal notice</a></li>\n    <li>&copy; Flinker 2026. Microsoft Partner.</li>\n  </ul>\n</div>",
    "_enableSearch": true,
    "_disableContribution": true,
    "pdf": false
  }
}
