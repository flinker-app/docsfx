{{!master(layout/_master.tmpl)}}

<div class="docs-overview">
  <header class="docs-overview-header">
    <h1>{{title}}</h1>
    {{#description}}
    <div class="docs-overview-description">{{{description}}}</div>
    {{/description}}
  </header>

  {{#items.Length}}
  <div class="vertical-card-container" aria-label="{{title}}">
    {{#items}}
    <a class="vertical-card{{^thumbnail}} vertical-card--text{{/thumbnail}}" href="{{href}}">
      {{#thumbnail}}
      <div class="vertical-card-media">
        <img src="{{thumbnail}}" alt="{{name}}" />
      </div>
      {{/thumbnail}}

      <div class="vertical-card-content">
        <h2 class="card-title">{{name}}</h2>
        {{#description}}
        <div class="card-description">{{{description}}}</div>
        {{/description}}

        {{#usage}}
        <div class="usage-block">
          {{#config}}
          <div class="list-group-item">
            <strong>docfx.json:</strong> <code>{{config}}</code>
          </div>
          {{/config}}
          {{#command}}
          <div class="list-group-item">
            <strong>docfx:</strong> <code>{{command}}</code>
          </div>
          {{/command}}
          {{#init}}
          <div class="list-group-item">
            <strong>docfx init:</strong> <code>{{init}}</code>
          </div>
          {{/init}}
        </div>
        {{/usage}}

        <span class="card-link">Learn more <i class="bi bi-chevron-right" aria-hidden="true"></i></span>
      </div>
    </a>
    {{/items}}
  </div>
  {{/items.Length}}
</div>
